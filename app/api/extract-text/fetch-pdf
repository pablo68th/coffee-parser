import { NextResponse } from "next/server";

function looksLikePdf(bytes: Uint8Array) {
  const head = new TextDecoder().decode(bytes.slice(0, 5));
  return head === "%PDF-";
}

function extractDriveFileId(url: string): string | null {
  try {
    const u = new URL(url);

    // Caso 1: https://drive.google.com/file/d/FILEID/view?usp=sharing
    const m1 = u.pathname.match(/\/file\/d\/([^/]+)/);
    if (m1?.[1]) return m1[1];

    // Caso 2: https://drive.google.com/open?id=FILEID
    const id = u.searchParams.get("id");
    if (id) return id;

    return null;
  } catch {
    return null;
  }
}

function tryFindConfirmToken(html: string): string | null {
  // Drive a veces pone confirm=XXXX en la página intermedia
  const m = html.match(/confirm=([0-9A-Za-z_]+)/);
  return m?.[1] ?? null;
}

export async function POST(req: Request) {
  try {
    const { url } = await req.json();

    if (!url || typeof url !== "string") {
      return NextResponse.json({ error: "Falta url" }, { status: 400 });
    }

    if (!/^https?:\/\//i.test(url)) {
      return NextResponse.json({ error: "URL inválida" }, { status: 400 });
    }

    let fetchUrl = url;

    // ✅ Caso Google Drive: convertimos a descarga directa
    const isDrive =
      /drive\.google\.com/i.test(url) || /docs\.google\.com/i.test(url);

    if (isDrive) {
      const fileId = extractDriveFileId(url);
      if (!fileId) {
        return NextResponse.json(
          { error: "Link de Google Drive no reconocido (no pude extraer el fileId)." },
          { status: 400 }
        );
      }
      fetchUrl = `https://drive.google.com/uc?export=download&id=${fileId}`;
    }

    // Fetch como “navegador”
    const res = await fetch(fetchUrl, {
      redirect: "follow",
      headers: {
        "user-agent":
          "Mozilla/5.0 (compatible; CoffeeParser/1.0; +https://coffee-parser.vercel.app)",
        accept: "application/pdf,application/octet-stream,text/html;q=0.9,*/*;q=0.8",
      },
    });

    if (!res.ok) {
      const ct = res.headers.get("content-type") || "";
      return NextResponse.json(
        { error: `No se pudo descargar. Status ${res.status}. content-type: ${ct || "—"}` },
        { status: 400 }
      );
    }

    const ct = (res.headers.get("content-type") || "").toLowerCase();

    // ✅ Google Drive a veces regresa HTML con confirm token
    if (isDrive && ct.includes("text/html")) {
      const html = await res.text();
      const token = tryFindConfirmToken(html);

      // Si no hay token, normalmente es porque NO tienes permiso (o el link no es público)
      if (!token) {
        return NextResponse.json(
          {
            error:
              "Google Drive no devolvió el PDF. Esto suele pasar si el archivo NO es público (Cualquiera con el vínculo) o Drive bloqueó la descarga.",
          },
          { status: 400 }
        );
      }

      // Reintento con confirm
      const fileId = extractDriveFileId(url);
      const confirmUrl = `https://drive.google.com/uc?export=download&confirm=${token}&id=${fileId}`;

      const res2 = await fetch(confirmUrl, {
        redirect: "follow",
        headers: {
          "user-agent":
            "Mozilla/5.0 (compatible; CoffeeParser/1.0; +https://coffee-parser.vercel.app)",
          accept: "application/pdf,application/octet-stream,*/*",
        },
      });

      if (!res2.ok) {
        const ct2 = res2.headers.get("content-type") || "";
        return NextResponse.json(
          { error: `Drive confirmó pero falló la descarga. Status ${res2.status}. content-type: ${ct2 || "—"}` },
          { status: 400 }
        );
      }

      const ab2 = await res2.arrayBuffer();
      const u8 = new Uint8Array(ab2);

      if (!looksLikePdf(u8)) {
        return NextResponse.json(
          { error: "Descargué algo desde Drive pero no parece PDF válido (no inicia con %PDF-)." },
          { status: 400 }
        );
      }

      return new NextResponse(ab2, {
        status: 200,
        headers: {
          "content-type": "application/pdf",
          "x-filename": "qr.pdf",
          "cache-control": "no-store",
        },
      });
    }

    // Caso general: PDF directo u octet-stream pero que “huela” a PDF
    const ab = await res.arrayBuffer();
    const u8 = new Uint8Array(ab);

    const isPdfByHeader = ct.includes("application/pdf");
    const isPdfByMagic = looksLikePdf(u8);

    if (!isPdfByHeader && !isPdfByMagic) {
      return NextResponse.json(
        { error: `El link no parece PDF (content-type: ${ct || "—"})` },
        { status: 400 }
      );
    }

    // Límite 12MB
    const maxBytes = 12 * 1024 * 1024;
    if (ab.byteLength > maxBytes) {
      return NextResponse.json({ error: "PDF demasiado grande (máx 12MB)" }, { status: 400 });
    }

    return new NextResponse(ab, {
      status: 200,
      headers: {
        "content-type": "application/pdf",
        "x-filename": "qr.pdf",
        "cache-control": "no-store",
      },
    });
  } catch (e: any) {
    return NextResponse.json({ error: e?.message ?? "Error inesperado" }, { status: 500 });
  }
}
